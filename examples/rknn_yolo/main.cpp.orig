static std::atomic<bool> g_stop{false};

static constexpr uint32_t align16(uint32_t v) {
    return (v + 15U) & ~15U;
}

static void signal_handler(int /*sig*/) {
    g_stop.store(true, std::memory_order_relaxed);
}

static std::string get_device_ip() {
    struct ifaddrs* ifas = nullptr;
    if (getifaddrs(&ifas) != 0) return "127.0.0.1";
    std::string result = "127.0.0.1";
    for (auto* ifa = ifas; ifa != nullptr; ifa = ifa->ifa_next) {
        if (!ifa->ifa_addr || ifa->ifa_addr->sa_family != AF_INET) continue;
        if (std::string(ifa->ifa_name) == "lo") continue;
        char buf[INET_ADDRSTRLEN];
        auto* sin = reinterpret_cast<struct sockaddr_in*>(ifa->ifa_addr);
        if (inet_ntop(AF_INET, &sin->sin_addr, buf, sizeof(buf))) {
            result = buf;
            break;
        }
    }
    freeifaddrs(ifas);
    return result;
}

static bool has_local_ip(const std::string& ip) {
    struct ifaddrs* ifas = nullptr;
    if (getifaddrs(&ifas) != 0) return false;
    bool found = false;
    for (auto* ifa = ifas; ifa != nullptr; ifa = ifa->ifa_next) {
        if (!ifa->ifa_addr || ifa->ifa_addr->sa_family != AF_INET) continue;
        char buf[INET_ADDRSTRLEN];
        auto* sin = reinterpret_cast<struct sockaddr_in*>(ifa->ifa_addr);
        if (inet_ntop(AF_INET, &sin->sin_addr, buf, sizeof(buf)) && ip == buf) {
            found = true;
            break;
        }
    }
    freeifaddrs(ifas);
    return found;
}

static std::string pick_source_ip() {
    if (has_local_ip("192.168.2.166")) return "192.168.2.166";
    return get_device_ip();
}

static int env_int(const char* name, int fallback, int min_v, int max_v) {
    const char* v = std::getenv(name);
    if (!v || !*v) return fallback;
    char* end = nullptr;
    long parsed = std::strtol(v, &end, 10);
    if (end == v || parsed < min_v || parsed > max_v) return fallback;
    return static_cast<int>(parsed);
}

static std::string env_string(const char* name, const char* fallback) {
    const char* v = std::getenv(name);
    return (v && *v) ? std::string(v) : std::string(fallback);
}

